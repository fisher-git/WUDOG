<view class="page">
  <view class="brand">
    <text class="logo">🏔</text>
    <text class="brand-name">乌东文旅</text>
    <text class="brand-desc">贵州苗寨一站式文旅服务平台</text>
  </view>
  <button class="wechat-btn" bindtap="onWechatLogin" loading="{{loading}}" disabled="{{loading}}">
    <text class="wechat-icon">💬</text> 微信一键登录
  </button>
  <view class="agreement">
    <checkbox checked="{{agreed}}" bindtap="onToggleAgreement"/>
    <text>我已阅读并同意 <text class="link">《用户协议》</text> 和 <text class="link">《隐私政策》</text></text>
  </view>
  <view class="alt-login">
    <text class="divider">———— 其他登录方式 ————</text>
    <text class="phone-login">📱 手机号注册/登录</text>
  </view>
</view>
