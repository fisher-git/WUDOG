.page { min-height: 100vh; background: #F5F5F5; padding-bottom: 120rpx; }
.cart-list { padding: 16rpx; }
.cart-item { display: flex; align-items: center; background: #fff; border-radius: 16rpx; padding: 16rpx; margin-bottom: 12rpx; gap: 12rpx; }
.cart-img { width: 140rpx; height: 140rpx; border-radius: 12rpx; flex-shrink: 0; }
.cart-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-height: 140rpx; }
.cart-name { font-size: 28rpx; color: #333; font-weight: bold; }
.cart-spec { font-size: 24rpx; color: #999; }
.cart-bottom { display: flex; justify-content: space-between; align-items: center; }
.cart-price { font-size: 30rpx; color: #C8A45C; font-weight: bold; }
.quantity-stepper { display: flex; align-items: center; gap: 8rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border-radius: 50%; background: #F0F0F0; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #666; }
.qty-value { font-size: 28rpx; color: #333; min-width: 48rpx; text-align: center; }
.delete-btn { font-size: 32rpx; padding: 8rpx; }

.cart-footer { position: fixed; bottom: 0; width: 100%; display: flex; align-items: center; background: #fff; padding: 16rpx 24rpx; box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06); gap: 16rpx; }
.cart-total { flex: 1; }
.total-price { font-size: 36rpx; color: #C8A45C; font-weight: bold; }
.checkout-btn { background: #C8A45C; color: #fff; border-radius: 40rpx; font-size: 28rpx; padding: 0 32rpx; }
