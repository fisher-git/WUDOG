.page { min-height: 100vh; background: #F5F5F5; }

.login-prompt { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.avatar-placeholder { width: 120rpx; height: 120rpx; border-radius: 50%; background: #E8E8E8; display: flex; align-items: center; justify-content: center; font-size: 60rpx; margin-bottom: 24rpx; }
.login-text { font-size: 28rpx; color: #999; margin-bottom: 40rpx; }
.login-btn { background: #07C160; color: #fff; border-radius: 40rpx; padding: 16rpx 64rpx; font-size: 32rpx; }

.user-header { display: flex; align-items: center; padding: 32rpx 24rpx; background: linear-gradient(135deg, #1B3A5C, #2A5A8C); }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; border: 3rpx solid #C8A45C; }
.user-info { flex: 1; margin-left: 20rpx; }
.nickname { font-size: 34rpx; color: #fff; font-weight: bold; display: block; }
.user-id { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 4rpx; }
.edit-link { color: #C8A45C; font-size: 26rpx; }

.order-bar { margin: 16rpx 24rpx; padding: 24rpx; }
.order-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.bar-title { font-size: 30rpx; font-weight: bold; }
.all-orders { color: #999; font-size: 24rpx; }
.order-items { display: flex; justify-content: space-around; }
.order-item { display: flex; flex-direction: column; align-items: center; position: relative; }
.order-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.order-label { font-size: 22rpx; color: #666; }
.order-badge { position: absolute; top: -8rpx; right: -16rpx; background: #FF4D4F; color: #fff; font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 20rpx; }

.menu-list { margin: 0 24rpx; }
.menu-item { display: flex; align-items: center; padding: 28rpx 24rpx; border-bottom: 1rpx solid #F5F5F5; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: #333; }
.menu-badge { background: #FF4D4F; color: #fff; font-size: 20rpx; padding: 2rpx 14rpx; border-radius: 20rpx; margin-right: 12rpx; }
.menu-arrow { color: #ccc; font-size: 28rpx; }

.logout-btn { margin: 48rpx 24rpx; background: #fff; color: #FF4D4F; border-radius: 12rpx; font-size: 28rpx; }
