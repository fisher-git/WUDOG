<view class="page">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-box">
      <input class="search-input" placeholder="搜索商品、民宿、路线..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" auto-focus/>
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="onClearKeyword">✕</text>
    </view>
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>

  <!-- 搜索前：历史+热搜 -->
  <view wx:if="{{!hasSearched}}">
    <!-- 搜索联想 -->
    <view class="suggestions" wx:if="{{suggestions.length > 0}}">
      <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="index" bindtap="onHistoryTap" data-keyword="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>

    <!-- 搜索历史 -->
    <view class="section" wx:if="{{history.length > 0 && suggestions.length === 0}}">
      <view class="section-header">
        <text class="section-label">搜索历史</text>
        <text class="clear-link" bindtap="onClearHistory">清空</text>
      </view>
      <view class="tag-group">
        <text class="tag" wx:for="{{history}}" wx:key="index" bindtap="onHistoryTap" data-keyword="{{item}}">{{item}}</text>
      </view>
    </view>

    <!-- 热门搜索 -->
    <view class="section" wx:if="{{suggestions.length === 0}}">
      <text class="section-label">🔥 热门搜索</text>
      <view class="tag-group">
        <text class="tag hot" wx:for="{{hotWords}}" wx:key="index" bindtap="onHotWordTap" data-keyword="{{item}}">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{hasSearched}}">
    <scroll-view scroll-x class="tabs">
      <text class="tab-item {{activeTab === item.key ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="key" data-key="{{item.key}}" bindtap="onTabChange">{{item.label}}</text>
    </scroll-view>

    <view wx:if="{{loading}}" class="loading">搜索中...</view>

    <view wx:elif="{{results.length === 0}}" class="empty-state">
      <text style="font-size:80rpx;">🔍</text>
      <text>未找到相关内容</text>
      <text style="color:#999;font-size:24rpx;margin-top:8rpx;">试试其他关键词吧</text>
    </view>

    <view wx:else class="result-list">
      <view class="result-item card" wx:for="{{results}}" wx:key="id">
        <image src="{{item.image || '/images/placeholder.jpg'}}" mode="aspectFill" class="result-img"/>
        <view class="result-info">
          <text class="result-title">{{item.title || item.name}}</text>
          <text class="result-desc">{{item.description || ''}}</text>
          <text class="result-price" wx:if="{{item.price}}">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
