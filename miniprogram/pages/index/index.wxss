.page { padding-bottom: 20rpx; }
.search-bar { display: flex; align-items: center; padding: 16rpx 24rpx; background: #fff; position: sticky; top: 0; z-index: 100; }
.search-input { flex: 1; display: flex; align-items: center; background: #F5F5F5; border-radius: 32rpx; padding: 12rpx 24rpx; }
.search-icon { margin-right: 8rpx; }
.search-placeholder { color: #999; font-size: 28rpx; }
.msg-icon { margin-left: 16rpx; font-size: 40rpx; }

.banner-swiper { width: 100%; height: 360rpx; }
.banner-image { width: 100%; height: 100%; }
.banner-title { position: absolute; bottom: 40rpx; left: 24rpx; color: #fff; font-size: 32rpx; font-weight: bold; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5); }

.category-grid { display: flex; justify-content: space-around; padding: 32rpx 24rpx; background: #fff; margin: 16rpx 0; }
.category-item { display: flex; flex-direction: column; align-items: center; }
.category-icon { width: 100rpx; height: 100rpx; border-radius: 20rpx; background: linear-gradient(135deg, #1B3A5C 0%, #2A5A8C 100%); display: flex; align-items: center; justify-content: center; font-size: 44rpx; }
.category-label { margin-top: 12rpx; font-size: 24rpx; color: #333; }

.section { padding: 0 24rpx; margin-bottom: 16rpx; }
.section-title { font-size: 36rpx; font-weight: bold; color: #1B3A5C; margin: 32rpx 0 20rpx; display: block; }

.activity-scroll { white-space: nowrap; }
.activity-card { width: 600rpx; height: 200rpx; margin-right: 16rpx; border-radius: 16rpx; overflow: hidden; display: inline-block; background-size: cover; background-position: center; }
.activity-mask { background: linear-gradient(transparent 40%, rgba(0,0,0,0.7)); height: 100%; display: flex; align-items: flex-end; padding: 16rpx; }
.activity-title { color: #fff; font-size: 28rpx; }

.recommend-scroll { white-space: nowrap; }
.recommend-card { display: inline-block; width: 240rpx; margin-right: 16rpx; }
.recommend-img { width: 240rpx; height: 180rpx; }
.recommend-info { padding: 12rpx; }
.recommend-name { font-size: 26rpx; color: #333; }

.culture-list { display: flex; flex-direction: column; gap: 20rpx; }
.culture-card { display: flex; }
.culture-img { width: 200rpx; height: 160rpx; border-radius: 12rpx 0 0 12rpx; flex-shrink: 0; }
.culture-info { padding: 16rpx; display: flex; flex-direction: column; justify-content: space-between; flex: 1; }
.culture-title { font-size: 28rpx; font-weight: bold; color: #333; }
.culture-desc { font-size: 24rpx; color: #666; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.culture-link { color: #C8A45C; font-size: 24rpx; }

.announce-list { background: #fff; border-radius: 16rpx; padding: 16rpx 24rpx; }
.announce-item { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.announce-item:last-child { border-bottom: none; }
.announce-dot { color: #C8A45C; margin-right: 12rpx; }
.announce-text { font-size: 26rpx; color: #333; }

.travelogue-waterfall { column-count: 2; column-gap: 16rpx; }
.travelogue-card { break-inside: avoid; margin-bottom: 16rpx; }
.travelogue-img { width: 100%; display: block; }
.travelogue-info { padding: 16rpx; }
.travelogue-title { font-size: 26rpx; color: #333; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; margin-bottom: 12rpx; }
.travelogue-meta { display: flex; align-items: center; gap: 8rpx; }
.author-avatar { width: 36rpx; height: 36rpx; border-radius: 50%; }
.author-name { font-size: 22rpx; color: #999; flex: 1; }
.like-count { font-size: 22rpx; color: #FF6B6B; }

.load-more { text-align: center; padding: 24rpx; color: #999; font-size: 24rpx; }
.skeleton-grid { display: flex; justify-content: space-around; padding: 32rpx 24rpx; }
.banner-skeleton { width: 100%; height: 360rpx; margin: 16rpx 0; border-radius: 0; }
